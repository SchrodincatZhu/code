# ── C++ 编译产物 ─────────────────────────────────────────────
bin/
*.exe
*.o

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── LaTeX 辅助文件（编译自动生成，无需追踪）────────────────────
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.toc
*.lof
*.lot
*.xdv
*.synctex.gz
.latexbuild/

# LaTeX 编译输出（本地查看即可，不纳入版本控制）
*.pdf

# LaTeX 源文件：默认不追踪
# 需要上传某个 .tex 时，执行：
#   git add -f 文件名.tex
#   git commit -m "add: ..."
# 首次强制添加后，后续该文件的修改会被 git 正常追踪，无需再加 -f
*.tex
