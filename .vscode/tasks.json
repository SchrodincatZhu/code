{
    "version": "2.0.0",
    "tasks": [
        // ── C++ 原有任务（保持不变）──────────────────────────────────
        {
            "type": "cppbuild",
            "label": "C/C++: g++ 生成活动文件",
            "command": "g++",
            "args": [
                "-g",
                "${fileDirname}\\${fileBasenameNoExtension}.cpp",
                "-o",
                "${workspaceFolder}\\bin\\${fileBasenameNoExtension}.exe",
                "--std=c++17"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        },
        {
            "type": "shell",
            "label": "删除活动文件",
            "command": "cmd",
            "args": [
                "/c",
                "del /Q \"${workspaceFolder}\\bin\\*\""
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "type": "shell",
            "label": "生成测试文件",
            "command": "cmd",
            "args": [
                "/c",
                "copy /Y \"${fileDirname}\\${fileBasenameNoExtension}.in\" \"${workspaceFolder}\\bin\\\""
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "输入文件启动",
            "dependsOn": [
                "C/C++: g++ 生成活动文件",
                "生成测试文件"
            ]
        },
        {
            "type": "shell",
            "label": "返回输出文件",
            "command": "cmd",
            "args": [
                "/c",
                "copy /Y \"${workspaceFolder}\\bin\\${fileBasenameNoExtension}.out\" \"${fileDirname}\\\""
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "完成带文件启动",
            "dependsOn": [
                "返回输出文件",
                "删除活动文件"
            ],
            "dependsOrder": "sequence"
        },
        {
            "type": "shell",
            "label": "运行程序",
            "dependsOn": [
                "C/C++: g++ 生成活动文件"
            ],
            "command": "cmd",
            "args": [
                "/c",
                "start cmd /k \"${workspaceFolder}\\bin\\${fileBasenameNoExtension}.exe\""
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        // ── Python 新增任务 ──────────────────────────────────────────
        {
            // 直接弹出新窗口运行 .py 文件（无输入/输出重定向）
            "type": "shell",
            "label": "Python: 运行程序",
            "command": "cmd",
            "args": [
                "/c",
                "start cmd /k \"python \\\"${fileDirname}\\${fileBasenameNoExtension}.py\\\"\""
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            // 将同目录下的 .in 文件复制进 bin，然后以文件重定向方式运行 Python
            // stdout 写入 bin\xxx.out，方便后续用"返回输出文件"取回
            "type": "shell",
            "label": "Python: 输入文件启动",
            "dependsOn": [
                "生成测试文件"
            ],
            "dependsOrder": "sequence",
            "command": "cmd",
            "args": [
                "/c",
                "python \"${fileDirname}\\${fileBasenameNoExtension}.py\" < \"${workspaceFolder}\\bin\\${fileBasenameNoExtension}.in\" > \"${workspaceFolder}\\bin\\${fileBasenameNoExtension}.out\""
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            // 完整流程：运行→取回输出→清理 bin
            "label": "Python: 完成带文件启动",
            "dependsOn": [
                "Python: 输入文件启动",
                "返回输出文件",
                "删除活动文件"
            ],
            "dependsOrder": "sequence"
        }
    ]
}